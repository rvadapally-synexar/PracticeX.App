# Copy to .env.local for local overrides. Vite reads .env.local last so it
# wins over .env / .env.production when running `npm run dev`.

# Where the API lives. In dev, the Vite proxy forwards /api to the .NET host
# on https://localhost:7100, so this can stay unset locally. In production
# (Cloudflare Pages), set this to the cloudflared tunnel URL or whatever
# permanent backend you've stood up.
VITE_API_BASE=
