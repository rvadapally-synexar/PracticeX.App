<Window x:Class="PracticeX.Agent.Ui.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:PracticeX.Agent.Ui"
        Title="PracticeX Facility Discovery Agent"
        Height="780" Width="1180"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgBrush}"
        Foreground="{StaticResource TextBrush}"
        FontFamily="Segoe UI"
        FontSize="13">
  <Grid Margin="20">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <!-- Title -->
    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
      <TextBlock Text="PracticeX Facility Discovery Agent" FontSize="22" FontWeight="SemiBold" />
      <TextBlock Text="Phase 1 Preview" FontSize="11" Foreground="{StaticResource AccentBrush}" Margin="12,8,0,0" />
    </StackPanel>

    <!-- Connection / API row -->
    <Grid Grid.Row="1" Margin="0,0,0,12">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="120" />
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="120" />
        <ColumnDefinition Width="280" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>
      <Label Grid.Column="0" Content="Connection:" VerticalAlignment="Center" />
      <ComboBox Grid.Column="1" x:Name="ConnectionCombo" DisplayMemberPath="Display" SelectedValuePath="Id" />
      <Label Grid.Column="2" Content="API base:" VerticalAlignment="Center" Margin="16,0,0,0" />
      <TextBox Grid.Column="3" x:Name="ApiBox" Text="https://localhost:7100" />
      <Button Grid.Column="4" x:Name="RefreshConnectionsBtn" Content="Refresh" Style="{StaticResource SecondaryButton}" Margin="12,0,0,0" Click="OnRefreshConnections" />
    </Grid>

    <!-- Folder row -->
    <Grid Grid.Row="2" Margin="0,0,0,12">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="120" />
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>
      <Label Grid.Column="0" Content="Folder:" VerticalAlignment="Center" />
      <TextBox Grid.Column="1" x:Name="FolderBox" Text="C:\Users\harek\SYNEXAR INC\Fundraising" />
      <Button Grid.Column="2" Content="Browse..." Style="{StaticResource SecondaryButton}" Margin="8,0,0,0" Click="OnBrowse" />
      <Button Grid.Column="3" x:Name="ScanBtn" Content="Scan folder" Margin="8,0,0,0" Click="OnScan" />
    </Grid>

    <!-- Bands row -->
    <Border Grid.Row="3" Background="{StaticResource PanelBrush}" CornerRadius="8" Padding="16,12" Margin="0,0,0,12">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Column="0">
          <TextBlock Text="Total" Foreground="{StaticResource MutedBrush}" />
          <TextBlock x:Name="TotalText" Text="0" FontSize="20" FontWeight="SemiBold" />
        </StackPanel>
        <StackPanel Grid.Column="1">
          <TextBlock Text="Strong" Foreground="{StaticResource GoodBrush}" />
          <TextBlock x:Name="StrongText" Text="0" FontSize="20" FontWeight="SemiBold" />
        </StackPanel>
        <StackPanel Grid.Column="2">
          <TextBlock Text="Likely" Foreground="{StaticResource AccentBrush}" />
          <TextBlock x:Name="LikelyText" Text="0" FontSize="20" FontWeight="SemiBold" />
        </StackPanel>
        <StackPanel Grid.Column="3">
          <TextBlock Text="Possible" Foreground="{StaticResource WarnBrush}" />
          <TextBlock x:Name="PossibleText" Text="0" FontSize="20" FontWeight="SemiBold" />
        </StackPanel>
        <StackPanel Grid.Column="4">
          <TextBlock Text="Skipped" Foreground="{StaticResource MutedBrush}" />
          <TextBlock x:Name="SkippedText" Text="0" FontSize="20" FontWeight="SemiBold" />
        </StackPanel>
      </Grid>
    </Border>

    <!-- Results table -->
    <DataGrid Grid.Row="4" x:Name="ResultsGrid"
              AutoGenerateColumns="False" CanUserAddRows="False"
              HeadersVisibility="Column" GridLinesVisibility="Horizontal"
              Background="{StaticResource PanelBrush}"
              Foreground="{StaticResource TextBrush}"
              RowBackground="{StaticResource PanelBrush}"
              AlternatingRowBackground="#192234"
              BorderBrush="#334155" BorderThickness="1"
              HorizontalGridLinesBrush="#334155"
              SelectionMode="Single">
      <DataGrid.Columns>
        <DataGridCheckBoxColumn Header="" Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" Width="36" />
        <DataGridTextColumn Header="Band" Binding="{Binding Band}" Width="80" IsReadOnly="True" />
        <DataGridTextColumn Header="Score" Binding="{Binding ConfidenceDisplay}" Width="60" IsReadOnly="True" />
        <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="220" IsReadOnly="True" />
        <DataGridTextColumn Header="Path" Binding="{Binding RelativePath}" Width="*" IsReadOnly="True" />
        <DataGridTextColumn Header="Type" Binding="{Binding CandidateType}" Width="120" IsReadOnly="True" />
        <DataGridTextColumn Header="Why" Binding="{Binding ReasonsDisplay}" Width="220" IsReadOnly="True" />
      </DataGrid.Columns>
      <DataGrid.ColumnHeaderStyle>
        <Style TargetType="DataGridColumnHeader">
          <Setter Property="Background" Value="#0B1220" />
          <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
          <Setter Property="FontWeight" Value="SemiBold" />
          <Setter Property="Padding" Value="8,6" />
          <Setter Property="BorderBrush" Value="#334155" />
          <Setter Property="BorderThickness" Value="0,0,1,0" />
        </Style>
      </DataGrid.ColumnHeaderStyle>
      <DataGrid.CellStyle>
        <Style TargetType="DataGridCell">
          <Setter Property="BorderThickness" Value="0" />
          <Setter Property="Padding" Value="6,4" />
          <Setter Property="Background" Value="Transparent" />
          <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        </Style>
      </DataGrid.CellStyle>
    </DataGrid>

    <!-- Selection bar -->
    <Grid Grid.Row="5" Margin="0,12,0,0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>
      <Button Grid.Column="0" Content="Select strong+likely" Style="{StaticResource SecondaryButton}" Click="OnSelectStrongLikely" />
      <Button Grid.Column="1" Content="Select all" Style="{StaticResource SecondaryButton}" Margin="8,0,0,0" Click="OnSelectAll" />
      <Button Grid.Column="2" Content="Clear" Style="{StaticResource SecondaryButton}" Margin="8,0,0,0" Click="OnClearSelection" />
      <TextBlock Grid.Column="3" x:Name="SelectionText" Text="0 selected" VerticalAlignment="Center" Margin="16,0,0,0" Foreground="{StaticResource MutedBrush}" />
      <Button Grid.Column="4" x:Name="UploadBtn" Content="Upload selected" IsEnabled="False" Click="OnUpload" />
    </Grid>

    <!-- Status -->
    <Border Grid.Row="6" Background="{StaticResource PanelBrush}" CornerRadius="6" Padding="12,8" Margin="0,12,0,0">
      <TextBlock x:Name="StatusText" Text="Ready. Pick a connection and a folder, then click Scan." Foreground="{StaticResource MutedBrush}" />
    </Border>
  </Grid>
</Window>
